{
 "deploy": {
  "base": {
   "image": "ghcr.io/gitlayzer/seapack-runtime:mise-2026.3.17"
  },
  "inputs": [
   {
    "include": [
     "."
    ],
    "step": "defaultsToUsing"
   },
   {
    "include": [
     "."
    ],
    "step": "usesSecrets"
   }
  ],
  "startCommand": "./run.sh"
 },
 "secrets": [
  "MY_SECRET",
  "MY_OTHER_SECRET",
  "HELLO_WORLD"
 ],
 "steps": [
  {
   "inputs": [
    {
     "image": "ghcr.io/gitlayzer/seapack-builder:mise-2026.3.17"
    }
   ],
   "name": "packages:mise"
  },
  {
   "commands": [
    {
     "dest": ".",
     "src": "."
    },
    {
     "cmd": "sh -c './run.sh'",
     "customName": "./run.sh"
    }
   ],
   "inputs": [
    {
     "step": "packages:mise"
    }
   ],
   "name": "defaultsToUsing",
   "secrets": [
    "*"
   ],
   "variables": {
    "NOT_SECRET": "not secret"
   }
  },
  {
   "commands": [
    {
     "dest": ".",
     "src": "."
    },
    {
     "cmd": "sh -c './run.sh'",
     "customName": "./run.sh"
    }
   ],
   "inputs": [
    {
     "step": "packages:mise"
    }
   ],
   "name": "usesSecrets",
   "secrets": [
    "MY_SECRET",
    "MY_OTHER_SECRET"
   ],
   "variables": {
    "NOT_SECRET": "not secret"
   }
  }
 ]
}